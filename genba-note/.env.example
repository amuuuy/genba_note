# ============================================
# ポチッと事務 - Environment Variables Template
# ============================================
# このファイルをコピーして .env を作成してください
# Copy this file to create .env
#
# 重要: 実際の値を入力する前に、以下のルールを確認してください
# - 秘密情報は絶対にGitにコミットしないこと
# - .env ファイルは .gitignore に含まれていることを確認すること
# ============================================

# ------------------------------------------
# API Configuration (Future)
# ------------------------------------------
# バックエンドAPIのベースURL（将来のAPI接続用）
# EXPO_PUBLIC_API_BASE_URL=

# API認証キー（将来のAPI接続用）
# API_KEY=

# ------------------------------------------
# Sentry (Crash Reporting)
# ------------------------------------------
# Sentry Data Source Name (DSN) - クラッシュレポート送信先
# (注意: DSN は公開値です。Auth Token とは別物です)
# Get from: https://sentry.io/ > Project Settings > Client Keys (DSN)
#
# EAS Build ではソースマップアップロード用に以下の EAS Secrets が必要:
#   1. eas secret:create --name SENTRY_AUTH_TOKEN --value <token>
#   2. eas secret:create --name SENTRY_ORG --value <organization-slug>
#   3. eas secret:create --name SENTRY_PROJECT --value <project-slug>
#
# 注意: SENTRY_ORG/SENTRY_PROJECT は環境変数として解決されます。
# app.json のプラグイン設定には url のみ記載（org/project は含めない）。
EXPO_PUBLIC_SENTRY_DSN=

# ------------------------------------------
# Analytics & Debugging (Future)
# ------------------------------------------
# アナリティクスを有効にするかどうか
# EXPO_PUBLIC_ANALYTICS_ENABLED=

# デバッグログを有効にするかどうか
# EXPO_PUBLIC_DEBUG_MODE=
