# ============================================
# ポチッと事務 - Environment Variables Template
# ============================================
# このファイルをコピーして .env を作成してください
# Copy this file to create .env
#
# 重要: 実際の値を入力する前に、以下のルールを確認してください
# - 秘密情報は絶対にGitにコミットしないこと
# - .env ファイルは .gitignore に含まれていることを確認すること
# ============================================

# ------------------------------------------
# App Environment
# ------------------------------------------
# アプリの実行環境を指定
# Options: development, staging, production
#
# Pro機能 (PDF出力・CSVエクスポート) への影響:
# - development/staging: Pro機能が自動有効化（IAP不要）
# - production: RevenueCatによる購入検証が必須
#
# 注意: App Store提出ビルドでは必ず production を設定すること
EXPO_PUBLIC_APP_ENV=

# ------------------------------------------
# RevenueCat (Subscription Management)
# ------------------------------------------
# RevenueCat Public SDK Key - クライアントサイドSDK用の公開キー
# (注意: これは公開キーです。秘密キーではありません)
# Get from: https://app.revenuecat.com/ > Project Settings > API Keys
EXPO_PUBLIC_REVENUECAT_PUBLIC_KEY=

# ------------------------------------------
# Supabase (Material Research API Proxy)
# ------------------------------------------
# Supabase プロジェクトURL
# Get from: https://supabase.com/dashboard > Project Settings > API
EXPO_PUBLIC_SUPABASE_URL=

# Supabase Publishable Key - クライアントサイド用の公開キー
# (注意: これは公開キーです。秘密キーではありません)
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# ------------------------------------------
# API Configuration (Future)
# ------------------------------------------
# バックエンドAPIのベースURL（将来のAPI接続用）
# EXPO_PUBLIC_API_BASE_URL=

# API認証キー（将来のAPI接続用）
# API_KEY=

# ------------------------------------------
# Gemini AI (Material Price Research)
# ------------------------------------------
# Gemini API Key は Supabase Edge Function のシークレットとして管理
# クライアント側の環境変数は不要です
# 設定方法: supabase secrets set GEMINI_API_KEY=<your_key>
# デプロイ: supabase functions deploy gemini-search --verify-jwt

# ------------------------------------------
# Sentry (Crash Reporting)
# ------------------------------------------
# Sentry Data Source Name (DSN) - クラッシュレポート送信先
# (注意: DSN は公開値です。Auth Token とは別物です)
# Get from: https://sentry.io/ > Project Settings > Client Keys (DSN)
#
# EAS Build ではソースマップアップロード用に以下の EAS Secrets が必要:
#   1. eas secret:create --name SENTRY_AUTH_TOKEN --value <token>
#   2. eas secret:create --name SENTRY_ORG --value <organization-slug>
#   3. eas secret:create --name SENTRY_PROJECT --value <project-slug>
#
# 注意: SENTRY_ORG/SENTRY_PROJECT は環境変数として解決されます。
# app.json のプラグイン設定には url のみ記載（org/project は含めない）。
EXPO_PUBLIC_SENTRY_DSN=

# ------------------------------------------
# Analytics & Debugging (Future)
# ------------------------------------------
# アナリティクスを有効にするかどうか
# EXPO_PUBLIC_ANALYTICS_ENABLED=

# デバッグログを有効にするかどうか
# EXPO_PUBLIC_DEBUG_MODE=
